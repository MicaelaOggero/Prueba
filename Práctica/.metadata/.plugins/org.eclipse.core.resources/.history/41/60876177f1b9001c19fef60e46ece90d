
public class Persona {
	private String nombre;
	private int edad;
	private String factor;
	
	public String getNombre() {
		return(nombre);
	}
	
	public void setNombre() {
		this.nombre=nombre;
	}
	
	public String getFactor() {
		return(factor);
	}
	
	public void setFactor() {
		this.factor=factor;
	}
	
	public int getEdad() {
		return(edad);
	}
	
	public void setEdad() {
		this.edad=edad;
	}

}
